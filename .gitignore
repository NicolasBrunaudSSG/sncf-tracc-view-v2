# ── Données sources (volumineuses / confidentielles) ──────────────────────────
inputs/

# ── GeoPackages sources (volumineuses) ───────────────────────────────────────
app/data/*.gpkg
# Conserver la structure du dossier
!app/data/.gitkeep

# ── Python ────────────────────────────────────────────────────────────────────
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
*.log

# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
app/frontend/dist/
app/frontend/.env.local
app/frontend/.env.production

# ── Variables d'environnement (secrets) ───────────────────────────────────────
.env
.env.*
!.env.example

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/settings.json
*.swp
